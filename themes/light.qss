}

/* й‘ҝж»ғеҙҹ */
QMenuBar {
    background-color: #ffffff;
    color: #333333;
    border-bottom: 1px solid #e0e0e0;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
}

QMenuBar::item:selected {
    background-color: #f5f5f5;
}

QMenuBar::item:pressed {
    background-color: #e8e8e8;
}

QMenu,
QMenu[unifiedMenu="true"] {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    padding: 6px;
}

QMenu::item,
QMenu[unifiedMenu="true"]::item {
    padding: 6px 24px 6px 12px;
    border-radius: 6px;
    margin: 1px 2px;
}

QMenu::item:selected,
QMenu[unifiedMenu="true"]::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}

QMenu::item:disabled,
QMenu[unifiedMenu="true"]::item:disabled {
    color: #999999;
    background: transparent;
}

QMenu::separator,
QMenu[unifiedMenu="true"]::separator {
    height: 1px;
    background-color: #e0e0e0;
    margin: 6px 8px;
}

QMenu QWidget[menuCheckItemContainer="true"],
QMenu[unifiedMenu="true"] QWidget[menuCheckItemContainer="true"] {
    background: transparent;
    border-radius: 6px;
    margin: 1px 2px;
}

QMenu QWidget[menuCheckItemContainer="true"]:hover,
QMenu[unifiedMenu="true"] QWidget[menuCheckItemContainer="true"]:hover,
QMenu QCheckBox[menuCheckItem="true"]:hover,
QMenu[unifiedMenu="true"] QCheckBox[menuCheckItem="true"]:hover {
    background-color: #f5f5f5;
}

QMenu QCheckBox[menuCheckItem="true"],
QMenu[unifiedMenu="true"] QCheckBox[menuCheckItem="true"] {
    background: transparent;
    color: #333333;
    padding: 6px 10px 6px 8px;
    spacing: 8px;
    border-radius: 6px;
}

/* е®ёгғҘеҸҝйҸҚ?*/
QToolBar {
    background-color: #f5f5f5;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    spacing: 4px;
    padding: 4px;
}

QToolBar QToolButton {
    background-color: transparent;
    color: #333333;
    border: none;
    border-radius: 4px;
    padding: 6px;
}

QToolBar QToolButton:hover {
    background-color: #e8e8e8;
}

QToolBar QToolButton:pressed {
    background-color: #d8d8d8;
}

QToolBar QToolButton:checked {
    background-color: #0078d4;
    color: #ffffff;
}

/* йҗҳиҲөвӮ¬дҪ№зҲ® */
QStatusBar {
    background-color: #f5f5f5;
    color: #666666;
    border-top: 1px solid #e0e0e0;
}

/* жҗҙжӣўе„ҙйҗҳиҲөвӮ¬дҪҪоҮӣйҺҜе‘®зҲЈз»ӣ?*/
#stepDetailLabel {
    background-color: rgba(180, 180, 180, 180);
    color: white;
    padding: 8px;
    border-radius: 5px;
    font-size: 9pt;
    border: none;
}

/* йҚ’е—ҷзІҚеҰ—?*/
QGroupBox {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    margin-top: 12px;
    padding-top: 12px;
    font-weight: bold;
}

QGroupBox::title {
    color: #333333;
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    background-color: #ffffff;
}

/* йҚӢж»ҲжҪ¬з»җжҘҖеҪӣ */
QDockWidget {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #e0e0e0;
    titlebar-close-icon: url(close.png);
    titlebar-normal-icon: url(float.png);
}

QDockWidget::title {
    background-color: #f5f5f5;
    padding: 6px;
    border-bottom: 1px solid #e0e0e0;
}

/* е®ёгғҘеҸҝйҺ»ж„®гҒҡ */
QToolTip {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 4px;
}

/* йҸғе¬ӯжөҶеҰ—?*/
QSpinBox, QDoubleSpinBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 6px;
    min-height: 24px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #0078d4;
}

QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    width: 0px;
    height: 0px;
    border: none;
}

/* йҸғгғҰж№ЎйҸғе •жЈҝй–«еӨӢе«ЁйҚЈ?*/
QDateEdit, QTimeEdit, QDateTimeEdit {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 6px;
}

QDateEdit:focus, QTimeEdit:focus, QDateTimeEdit:focus {
    border-color: #0078d4;
}

QCalendarWidget {
    background-color: #ffffff;
    color: #333333;
}

QCalendarWidget QToolButton {
    color: #333333;
    background-color: #f5f5f5;
}

QCalendarWidget QMenu {
    background-color: #ffffff;
    color: #333333;
}

QCalendarWidget QSpinBox {
    background-color: #ffffff;
    color: #333333;
}

QCalendarWidget QAbstractItemView {
    background-color: #ffffff;
    color: #333333;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
}

/* йҚ’е——еЈҠйҚЈ?*/
QSplitter::handle {
    background-color: #e0e0e0;
}

QSplitter::handle:hover {
    background-color: #d0d0d0;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:vertical {
    height: 2px;
}

/* зҖөзЎ…зҳҪеҰ—е—ҳеҜңй–Ҫ?*/
QDialogButtonBox QPushButton {
    min-width: 80px;
}

/* QMessageBox йҸҚеі°зҙЎ */
QMessageBox {
    background-color: #ffffff;
}

QMessageBox QPushButton {
    background-color: #f5f5f5;
    color: #333333;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    padding: 6px 16px;
    min-width: 80px;
    min-height: 24px;
}

QMessageBox QPushButton:hover {
    background-color: #e8e8e8;
    border-color: #d0d0d0;
}

QMessageBox QPushButton:pressed {
    background-color: #d8d8d8;
    border-color: #0078d4;
}

/* йҚ—пј„еў–йҸҚеі°зҙЎ */
QFrame[frameShape="4"] {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
}

/* й‘·оҒ„з•ҫж¶”еӨҠеҙұйҗ—еӣЁзҲЈжЈ°?*/
QLabel[cardTitle="true"] {
    background-color: #f0f0f0;
    color: #333333;
    padding: 8px;
    font-weight: bold;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

/* йҸҚеӣ©о„·жӨӨеһ«её¶жө ?*/
QTabWidget {
    background-color: #ffffff;
    border: none;
}

QTabWidget::pane {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    top: -1px;
}

QTabBar {
    background-color: #ffffff;
}

QTabBar::tab {
    background-color: #f5f5f5;
    color: #666666;
    border: 1px solid #e0e0e0;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    padding: 8px 20px;
    margin-right: 2px;
    min-width: 80px;
}

QTabBar::tab:hover {
    background-color: #e8e8e8;
    color: #333333;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #333333;
    border-bottom: 2px solid #0078d4;
    font-weight: 600;
}

QTabBar::tab:!selected {
    margin-top: 2px;
}

/* йҸҚеӣ©о„·жӨӨйқӣеҸ§й—Ӯо…ҹеҜңй–Ҫ?*/
QTabBar::close-button {
    background-color: transparent;
    border-radius: 2px;
    padding: 2px;
}

QTabBar::close-button:hover {
    background-color: #e0e0e0;
}

QTabBar::close-button:pressed {
    background-color: #d0d0d0;
}

/* й‘·оҒ„з•ҫж¶”еӨӢзҲЈз»ӣй№ғгҖүйҚҸжҠҪжЈҙйҺёеӨҗжҢій”ӣеңҰPushButtonй”ӣ?*/
QPushButton#tabCloseButton {
    background: transparent;
    border: none;
    color: #666666;
    font-size: 16px;
    font-weight: bold;
    padding: 0px;
    margin: 0px;
}

QPushButton#tabCloseButton:hover {
    background: #e81123;
    color: white;
    border-radius: 2px;
}

/* йҸҚеӣ©о„·жӨӨеһ«еқҠйҚ”зҠіеҜңй–Ҫ?*/
QTabBar QToolButton {
    background-color: transparent;
    border: none;
    border-radius: 4px;
    padding: 4px;
    color: #666666;
}

QTabBar QToolButton:hover {
    background-color: #e8e8e8;
    color: #333333;
}

/* ========== й‘·оҒ„з•ҫж¶”еӨүз¬…йҺ·еӨӢо”ӢйҸҚеі°зҙЎ ========== */

/* ж¶“е¬«еӘәеҰ—е—ҳеҜңй–Ҫ?*/
QPushButton#customDropdownButton {
    text-align: left;
    padding: 6px;
    padding-right: 30px;
    min-height: 24px;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    background-color: #ffffff;
    color: #333333;
}

QPushButton#customDropdownButton:hover {
    border-color: #b0b0b0;
}

QPushButton#customDropdownButton:pressed {
    background-color: #f5f5f5;
}

QPushButton#customDropdownButton:focus {
    border-color: #0078d4;
}

/* ж¶“е¬«еӘәеҰ—е——и„ҠйҚ‘зғҳо”Ӣ */
QFrame#customDropdownPopup {
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    background-color: #ffffff;
    padding: 0px;
    margin: 0px;
}

/* й–«ж°ұж•ӨйҚ’жҘ„гҖғйҸҚеі°зҙЎ */
QListWidget {
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    background-color: #ffffff;
    outline: none;
}

QListWidget::item {
    border-radius: 4px;
    margin: 1px 2px;
}

QListWidget::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}

QListWidget::item:hover:!selected {
    background-color: #f0f0f0;
}

/* ж¶“е¬«еӘәеҰ—е——еһӘзҗӣ?*/
QListWidget#customDropdownList {
    border: none;
    background-color: transparent;
    outline: none;
    show-decoration-selected: 1;
}

QListWidget#customDropdownList::viewport {
    background-color: transparent;
}

QListWidget#customDropdownList::item {
    padding: 0px;
    min-height: 18px;
    color: #333333;
    background-color: #ffffff;
    text-align: left;
    border-radius: 4px;
    margin: 0px;
}

QListWidget#customDropdownList::item:hover {
    background-color: transparent;
    color: #333333;
}

QListWidget#customDropdownList::item:selected {
    background-color: transparent;
    color: #333333;
}

QListWidget#customDropdownList::item:selected:hover {
    background-color: transparent;
    color: #333333;
}

/* й‘·оҒ„з•ҫж¶”еӨӢзҲЈжЈ°жЁ»зҲ® */
#CustomTitleBar {
    background-color: #f5f5f5;
    border-bottom: none;
}

/* з’§зӮІе§ӘйҺёеӨҗжҢійҗ—и§„з•©йҸҚеі°зҙЎ - и№Үе‘ҙгҖҸйҚҰг„©вӮ¬ж°ұж•ӨйҸҚеі°зҙЎж¶”е¬Әеў зҖ№ж°«з®ҹжө гғ§вҖҳж·Үжҝ…зҙӯйҚҸе ўйӘҮ */
#CustomTitleBar QToolButton#sponsorButton {
    color: #ff4757 !important;
    font-size: 18px;
    background-color: transparent;
    border: none;
    padding: 4px;
    border-radius: 4px;
}

#CustomTitleBar QToolButton#sponsorButton:hover {
    background-color: rgba(255, 71, 87, 0.2);
    color: #ff1744 !important;
}

#CustomTitleBar QToolButton#sponsorButton:pressed {
    background-color: rgba(255, 71, 87, 0.3);
    color: #d50000 !important;
}

#CustomTitleBar QToolButton {
    background-color: transparent;
    border: none;
    padding: 4px;
    border-radius: 4px;
    color: #333333;
}

#CustomTitleBar QToolButton:hover {
    background-color: #e8e8e8;
}

#CustomTitleBar QToolButton:pressed {
    background-color: #d8d8d8;
}

#CustomTitleBar QToolButton:disabled {
    opacity: 0.5;
}

/* йҸҚеӣ¬о•ҪйҸҚеҝ•зҚҘйҚҷпҪҶеҜңй–Ҫ?*/
#CustomTitleBar QPushButton#windowButton {
    background-color: transparent;
    border: none;
    padding: 0px 10px;
    margin: 0px 2px;
    border-radius: 4px;
    color: #666666;
    font-family: "Segoe UI Symbol", "Segoe UI Emoji", "Arial";
    font-size: 14px;
    min-width: 36px;
    min-height: 30px;
}

#CustomTitleBar QPushButton#windowButton:hover {
    background-color: #e8e8e8;
    color: #333333;
}

#CustomTitleBar QPushButton#windowButton:pressed {
    background-color: #d8d8d8;
}

/* йҚҸжҠҪжЈҙйҺёеӨҗжҢійҗ—и§„з•©йҸҚеі°зҙЎ */
#CustomTitleBar QPushButton#closeButton {
    background-color: transparent;
    border: none;
    padding: 0px 10px;
    margin: 0px 2px;
    border-radius: 4px;
    color: #666666;
    font-family: "Segoe UI Symbol", "Segoe UI Emoji", "Arial";
    font-size: 14px;
    min-width: 36px;
    min-height: 30px;
}

#CustomTitleBar QPushButton#closeButton:hover {
    background-color: #e81123;
    color: white;
}

#CustomTitleBar QPushButton#closeButton:pressed {
    background-color: #b00000;
    color: white;
}

#CustomTitleBar QLabel#titleLabel {
    color: #333333;
    background-color: transparent;
}

/* ========== йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҸҚеі°зҙЎ ========== */
/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳж¶“иҜІоҶҗйҚЈ?*/
ParameterPanel {
    background-color: #f5f7f9;
    border: none;
    border-radius: 8px;
    font-size: 10pt;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘QComboBox - зәӯоҶ»з№ҡеҜ®з‘°еҡӯеҰ—е—ҳзүұеҜ®еҝ”о„ңзәӯ?*/

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘QComboBoxеҜ®з‘°еҡӯеҰ—?- йҚҸжҠҪж•ӯй”ӣж°ұжҙҝйҺәгғҘз•ҫж¶”еӨҠи„ҠйҚ‘зғҳо”ӢйҸҚеі°зҙЎ */
ParameterPanel QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #707070;
    border-radius: 6px;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
    outline: none;
    padding: 2px;
}

ParameterPanel QComboBox QAbstractItemView::item {
    padding: 6px 12px;
    min-height: 20px;
    border: none;
    border-radius: 3px;
    margin: 0px;
}

ParameterPanel QComboBox QAbstractItemView::item:hover {
    background-color: #e8e8e8;
}

ParameterPanel QComboBox QAbstractItemView::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘Frame */
ParameterPanel QFrame {
    border: none;
    border-radius: 6px;
    padding: 4px;
}

ParameterPanel QComboBox QFrame {
    border: 1px solid #707070;
    border-radius: 6px;
    background-color: #ffffff;
    padding: 0px;
}

ParameterPanel QFrame#customDropdownPopup {
    padding: 0px;
    margin: 0px;
}

ParameterPanel QListWidget#customDropdownList {
    border: none;
    border-radius: 0px;
    background-color: transparent;
    padding: 0px;
    margin: 0px;
}

ParameterPanel QListWidget#customDropdownList::viewport {
    background-color: transparent;
    padding: 0px;
    margin: 0px;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘Label */
ParameterPanel QLabel {
    font-family: "Microsoft YaHei";
    font-size: 9pt;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘йҺёеӨҗжҢі */
ParameterPanel QPushButton {
    padding: 6px 12px;
    border: none;
    border-radius: 4px;
    font-family: "Microsoft YaHei";
    min-height: 22px;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҸҚеӣ¬о•ҪйҸҚеҝ“еҸ§й—Ӯо…ҹеҜңй–Ҫ?*/
ParameterPanel QPushButton#windowButton {
    background-color: transparent;
    background: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
    border-radius: 4px;
    color: #666666;
    font-family: "Segoe UI Symbol", "Segoe UI Emoji", "Arial";
    font-size: 12px;
    min-width: 36px;
    max-width: 36px;
    min-height: 28px;
    max-height: 28px;
}

ParameterPanel QPushButton#windowButton:!hover {
    background-color: transparent;
    background: transparent;
}

ParameterPanel QPushButton#windowButton:hover {
    background-color: #f44336;
    color: #ffffff;
}

ParameterPanel QPushButton#windowButton:pressed {
    background-color: #d32f2f;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘жқҲж’іеҸҶеҰ—?*/
ParameterPanel QLineEdit,
ParameterPanel QSpinBox,
ParameterPanel QDoubleSpinBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    padding: 5px;
    padding-right: 20px;
    border-radius: 4px;
    min-height: 18px;
    font-family: "Microsoft YaHei";
}

/* й—…ж„ҜжЈҢSpinBoxйҺёеӨҗжҢі */
ParameterPanel QSpinBox::up-button,
ParameterPanel QSpinBox::down-button,
ParameterPanel QDoubleSpinBox::up-button,
ParameterPanel QDoubleSpinBox::down-button {
    width: 0px;
    height: 0px;
    border: none;
    background: transparent;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘CheckBox */
ParameterPanel QCheckBox {
    font-family: "Microsoft YaHei";
    spacing: 8px;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘GroupBox */
ParameterPanel QGroupBox {
    font-weight: bold;
    border: none;
    border-radius: 6px;
    margin-top: 10px;
    padding: 10px;
    font-family: "Microsoft YaHei";
}

ParameterPanel QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    left: 10px;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘PlainTextEdit */
ParameterPanel QPlainTextEdit {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 8px;
    font-family: "Microsoft YaHei";
}

ParameterPanel QPlainTextEdit:focus {
    border-color: #0078d4;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҚҗе‘Ҝж®‘ScrollArea */
ParameterPanel QScrollArea {
    border-radius: 4px;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҗ—и§„з•©йҺёеӨҗжҢі - ж¶“жҳҸоӣҰйҺҝе¶„з¶”йҺёеӨҗжҢі(й’ғжҝҠеЈҠ) */
ParameterPanel QPushButton[class="primary"] {
    background-color: #0078D4;
    color: white;
}

ParameterPanel QPushButton[class="primary"]:hover {
    background-color: #1084d8;
}

ParameterPanel QPushButton[class="primary"]:pressed {
    background-color: #006cbe;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҗ—и§„з•©йҺёеӨҗжҢі - йҚ—йҒҚж«“йҺҝе¶„з¶”йҺёеӨҗжҢі(з»ҫгҲЈеЈҠ) */
ParameterPanel QPushButton[class="danger"] {
    background-color: #DC3545;
    color: white;
}

ParameterPanel QPushButton[class="danger"]:hover {
    background-color: #c82333;
}

ParameterPanel QPushButton[class="danger"]:pressed {
    background-color: #bd2130;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҗ—и§„з•©йҺёеӨҗжҢі - еЁҶВӨоӣҰйҺҝе¶„з¶”йҺёеӨҗжҢі(йҗҸжӢҢеЈҠ) */
ParameterPanel QPushButton[class="secondary"] {
    background-color: #6C757D;
    color: white;
}

ParameterPanel QPushButton[class="secondary"]:hover {
    background-color: #5a6268;
}

ParameterPanel QPushButton[class="secondary"]:pressed {
    background-color: #545b62;
}

/* йҚҷеӮӣжҡҹй—ҲгҲЎжҫҳйҗҳиҲөвӮ¬дҪ№зҲЈз»ӣ?*/
#parameterStatusLabel {
    background-color: rgba(180, 180, 180, 180);
    color: white;
    padding: 8px;
    border-radius: 5px;
    font-size: 9pt;
    border: none;
    margin: 0px;
}

/* иӨ°жӣһеҹ—йҚҘзӮҙж–Ғе®ёгғҘеҸҝйҺёеӨҗжҢі */
#recordReplayButton {
    background-color: #D83B01;
    color: white;
    border: none;
    font-weight: bold;
}

#recordReplayButton:hover {
    background-color: #A52A00;
}

#recordReplayButton:pressed {
    background-color: #7A1F00;
}

/* йҚҷж Ёз§·йҺёеӨҗжҢій”ӣе ҘвӮ¬ж°ұж•ӨйҚ—йҒҚж«“йҺҝе¶„з¶”йҺёеӨҗжҢій”ӣ?*/
#cancelButton {
    background-color: #D13438;
    color: white;
    border: none;
}

#cancelButton:hover {
    background-color: #A82A2D;
}

#cancelButton:pressed {
    background-color: #8B1F23;
}

/* ========== й–«еӨӢе«Ёжө иҜІе§ҹзҖөзЎ…зҳҪеҰ—е—ҳзүұеҜ®?========== */

/* жө иҜІе§ҹй–«еӨӢе«ЁйҺёеӨҗжҢі */
#taskButton {
    background-color: #f8f8f8;
    color: #333333;
    border: 1px solid #ccc;
}

#taskButton:hover {
    background-color: #e8e8e8;
    border-color: #007AFF;
}

#taskButton:checked {
    background-color: #007AFF;
    color: white;
    border-color: #007AFF;
}

#taskButton:disabled {
    background-color: #f0f0f0;
    color: #999999;
    border-color: #ddd;
}

/* зәӯоҶјз•ҫйҺёеӨҗжҢі */
#okButton {
    background-color: #007AFF;
    color: white;
    border: none;
}

#okButton:hover {
    background-color: #005ECB;
}

#okButton:pressed {
    background-color: #004BAA;
}

/* й—…еҝ”жәҖз’әе® жөҶйҗ©оҶҪзҲЈйҚ—пј„еў– */
QFrame#randomTargetCard {
    border: 1px solid #ddd;
    border-radius: 4px;
    background-color: white;
}

QFrame#randomTargetCard:hover {
    background-color: #f0f0f0;
    border-color: #aaa;
}

/* ========== еЁҙоҶје§©йҗҳиҲөвӮ¬дҪәзҚҘйҚҷ?========== */

/* еЁҙоҶје§©з»җжҘҖеҪӣзҖ№з‘°ж«’ */
#floatingContainer {
    background-color: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
}

/* йҗҳиҲөвӮ¬дҪ№жһғзҖӣ?*/
#floatingStatusLabel {
    color: #333333;
    font-size: 12px;
    font-weight: normal;
    background: transparent;
    border: none;
    padding: 0px;
}

/* и№ҮоӮЈеөҺй–ҝоҶҪеҪҒз»Җ?*/
#floatingHotkeyLabel {
    color: #888888;
    font-size: 10px;
    background: transparent;
    border: none;
    padding: 0px;
}

/* йҺәСғеҹ—йҺёеӨҗжҢі */
#floatingCtrlBtn {
    background-color: #f0f0f0;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    color: #333333;
    font-size: 9px;
    padding: 0px;
}

#floatingCtrlBtn:hover {
    background-color: #e0e0e0;
    border-color: #c0c0c0;
}

#floatingCtrlBtn:pressed {
    background-color: #d0d0d0;
}

#floatingCtrlBtn:disabled {
    color: #aaaaaa;
    background-color: #f5f5f5;
    border-color: #e0e0e0;
}

/* зҒһжӣһзҙ‘йҺёеӨҗжҢі */
#floatingExpandBtn {
    background-color: transparent;
    border: none;
    color: #888888;
    font-size: 8px;
    padding: 0px;
}

#floatingExpandBtn:hover {
    color: #333333;
}

/* йҸғгғҘз№”й—ҲгҲЎжҫҳ */
#floatingLogPanel {
    background: transparent;
    border: none;
}

/* йҸғгғҘз№”з‘ҷе——жөҳ */
#floatingLogView {
    background-color: #fafafa;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    color: #333333;
    font-family: "Consolas", "Microsoft YaHei UI", monospace;
    font-size: 11px;
    padding: 4px;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
}

/* Workflow canvas */
QGraphicsView#workflowView {
    background-color: #ffffff;
    border: none;
}

QGraphicsView#workflowView QAbstractScrollArea::viewport {
    background: #ffffff;
}

QGraphicsView#workflowView QScrollBar:vertical,
QGraphicsView#workflowView QScrollBar:horizontal {
    border: none;
    background: transparent;
}

QGraphicsView#workflowView QAbstractScrollArea::corner {
    border: none;
    background: transparent;
}

QGraphicsView#workflowView::corner {
    border: none;
    background: transparent;
}

QTabWidget#workflowTabs::pane {
    border: none;
}


