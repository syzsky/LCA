п»ҝ/* жөңоҶҝеЈҠж¶“е©ҡо•ҪйҸҚеі°зҙЎзҗӣ?*/

/* йҚҸг„Ҙзң¬йҸҚеі°зҙЎ */
* {
    color: #333333;
    font-family: "Microsoft YaHei UI", "Segoe UI", Arial, sans-serif;
    outline: none;
}

/* йҺёеӨҗжҢіз»ӮдҪәж•Өйҗ’пёҫеҒЈй“Ҹж°ұеҡҺ */
QPushButton, QToolButton, QCommandLinkButton {
    outline: none;
}

QPushButton:focus, QToolButton:focus, QCommandLinkButton:focus {
    outline: none;
}

/* ж¶“иҚӨзҚҘйҚҷпҪ…жӢ°зҖөзЎ…зҳҪеҰ—?*/
QMainWindow, QDialog, QWidget {
    background-color: #ffffff;
    color: #333333;
}

/* ж¶“о…һгҒҺйҚ–е“„з…ҷ */
#CentralFrame {
    background-color: #ffffff;
}

/* йҺёеӨҗжҢійҸҚеі°зҙЎ */
QPushButton {
    background-color: #f5f5f5;
    color: #333333;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    padding: 6px 16px;
    min-height: 22px;
}

QPushButton:hover {
    background-color: #e8e8e8;
    border-color: #d0d0d0;
}

QPushButton:pressed {
    background-color: #d8d8d8;
    border-color: #c0c0c0;
}

QPushButton:disabled {
    background-color: #fafafa;
    color: #999999;
    border-color: #e8e8e8;
}

QPushButton:checked {
    background-color: #0078d4;
    border-color: #0078d4;
    color: #ffffff;
}

/* ж¶“жҳҸоӣҰйҺҝе¶„з¶”йҺёеӨҗжҢі */
QPushButton[primary="true"] {
    background-color: #0078d4;
    color: #ffffff;
    border-color: #0078d4;
}

QPushButton[primary="true"]:hover {
    background-color: #1084d8;
}

QPushButton[primary="true"]:pressed {
    background-color: #006cbe;
}

/* йҗ—и§„з•©йҚ”зҶ»е…ҳйҺёеӨҗжҢі */
#assignAllButton {
    background-color: #4CAF50;
    color: white;
    border: none;
    font-weight: bold;
}

#assignAllButton:hover {
    background-color: #45a049;
}

#assignAllButton:pressed {
    background-color: #3d8b40;
}

#stopAllButton {
    background-color: #f44336;
    color: white;
    border: none;
    font-weight: bold;
}

#stopAllButton:hover {
    background-color: #d32f2f;
}

#stopAllButton:pressed {
    background-color: #b71c1c;
}

/* зҖӣжҘҖз°ұе®ёгғҘеҸҝйҺёеӨҗжҢійҸҚеі°зҙЎ */
#dictCaptureButton {
    background-color: #4CAF50;
    color: white;
    border: none;
    font-weight: bold;
}

#dictCaptureButton:hover {
    background-color: #45a049;
}

#dictCaptureButton:pressed {
    background-color: #3d8b40;
}

#dictImportButton {
    background-color: #0078d4;
    color: white;
    border: none;
}

#dictImportButton:hover {
    background-color: #1084d8;
}

#dictImportButton:pressed {
    background-color: #006cbe;
}

#dictDeleteButton {
    background-color: #f44336;
    color: white;
    border: none;
}

#dictDeleteButton:hover {
    background-color: #d32f2f;
}

#dictDeleteButton:pressed {
    background-color: #b71c1c;
}

#dictApplyBinaryButton {
    background-color: #ff9800;
    color: white;
    border: none;
    font-weight: bold;
}

#dictApplyBinaryButton:hover {
    background-color: #fb8c00;
}

#dictApplyBinaryButton:pressed {
    background-color: #f57c00;
}

#dictPreviewLabel {
    border: 1px solid #e0e0e0;
    background-color: #f5f5f5;
}

#saveButton {
    background-color: #28a745;
    color: white;
    border: none;
    font-weight: bold;
}

#saveButton:hover {
    background-color: #218838;
}

#saveButton:pressed {
    background-color: #1e7e34;
}

#testReplayButton {
    background-color: #17a2b8;
    color: white;
    border: none;
    font-weight: bold;
}

#testReplayButton:hover {
    background-color: #138496;
}

#testReplayButton:pressed {
    background-color: #0f6674;
}

/* жқҲж’іеҸҶеҰ—?*/
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 6px;
    min-height: 24px;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #0078d4;
}

QLineEdit:disabled, QTextEdit:disabled, QPlainTextEdit:disabled {
    background-color: #f5f5f5;
    color: #999999;
    border-color: #e0e0e0;
}

/* ж¶“е¬«еӘәеҰ—?*/
QComboBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 6px;
    min-height: 24px;
}

QComboBox:hover {
    border-color: #b0b0b0;
}

QComboBox:focus {
    border-color: #0078d4;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border: none;
    border-left: 1px solid #d0d0d0;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}


QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #707070;
    border-radius: 6px;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
    outline: none;
    padding: 2px;
}

QComboBox QAbstractItemView::viewport {
    background-color: #ffffff;
    border-radius: 6px;
}

QComboBox QAbstractItemView::item {
    padding: 6px 12px;
    min-height: 20px;
    border: none;
    border-radius: 3px;
    margin: 1px 2px;
}

QComboBox QListView {
    border: 1px solid #707070;
    border-radius: 6px;
    outline: none;
    background-color: #ffffff;
}

QComboBox QFrame {
    border: 1px solid #707070;
    border-radius: 6px;
    background-color: #ffffff;
}

QComboBox QAbstractScrollArea {
    border-radius: 6px;
}

QComboBox QAbstractScrollArea::corner {
    background-color: #ffffff;
    border: none;
    border-bottom-right-radius: 6px;
}

QComboBox QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 0px;
    border: none;
}

QComboBox QScrollBar::handle:vertical {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    min-height: 30px;
    margin: 2px;
}

QComboBox QScrollBar::handle:vertical:hover,
QComboBox QScrollBar::handle:vertical:pressed {
    background-color: rgba(0, 0, 0, 0.35);
}

QComboBox QScrollBar::add-line:vertical,
QComboBox QScrollBar::sub-line:vertical {
    height: 0px;
    background: transparent;
}

QComboBox QScrollBar::add-page:vertical,
QComboBox QScrollBar::sub-page:vertical {
    background: transparent;
}

QComboBox QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
    margin: 0px;
    border: none;
}

QComboBox QScrollBar::handle:horizontal {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    min-width: 30px;
    margin: 2px;
}

QComboBox QScrollBar::handle:horizontal:hover,
QComboBox QScrollBar::handle:horizontal:pressed {
    background-color: rgba(0, 0, 0, 0.35);
}

QComboBox QScrollBar::add-line:horizontal,
QComboBox QScrollBar::sub-line:horizontal {
    width: 0px;
    background: transparent;
}

QComboBox QScrollBar::add-page:horizontal,
QComboBox QScrollBar::sub-page:horizontal {
    background: transparent;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #e8e8e8;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}

/* Hide combo popup scroll buttons (up/down triangles) */
QComboBox QAbstractItemView QToolButton#qt_scrollarea_up_button,
QComboBox QAbstractItemView QToolButton#qt_scrollarea_down_button {
    width: 0px;
    height: 0px;
    border: none;
    background: transparent;
    padding: 0px;
    margin: 0px;
    image: none;
}

/* жҫ¶е¶үвӮ¬еӨӢо”Ӣ */
QCheckBox {
    color: #333333;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    background-color: #ffffff;
}

QCheckBox::indicator:hover {
    border-color: #b0b0b0;
}

QCheckBox::indicator:checked {
    background-color: #0078d4;
    border-color: #0078d4;
    image: url(themes/icons/check-white.svg);
}

QCheckBox::indicator:checked:hover {
    background-color: #1084d8;
    border-color: #1084d8;
}

QCheckBox::indicator:disabled {
    background-color: #f5f5f5;
    border-color: #e0e0e0;
}

/* йҚ—жӣўвӮ¬еӨӢо”Ӣ */
QRadioButton {
    color: #333333;
    spacing: 8px;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid #d0d0d0;
    border-radius: 9px;
    background-color: #ffffff;
}

QRadioButton::indicator:hover {
    border-color: #b0b0b0;
}

QRadioButton::indicator:checked {
    background-color: #0078d4;
    border-color: #0078d4;
}

QRadioButton::indicator:checked::after {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background-color: #ffffff;
}

/* е©ҠжҲқжҪЎ */
QSlider::groove:horizontal {
    height: 4px;
    background-color: #d0d0d0;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    width: 16px;
    height: 16px;
    margin: -6px 0;
    background-color: #0078d4;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #1084d8;
}

/* жқ©ж¶ҳе®ійҸү?*/
QProgressBar {
    background-color: #f5f5f5;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    text-align: center;
    color: #333333;
    height: 20px;
}

QProgressBar::chunk {
    background-color: #0078d4;
    border-radius: 3px;
}

/* йҸҚеӣ©о„·жӨӨ?*/
QTabWidget::pane {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
}

QTabBar::tab {
    background-color: #f5f5f5;
    color: #666666;
    border: 1px solid #e0e0e0;
    border-bottom: none;
    padding: 8px 16px;
    margin-right: 2px;
}

QTabBar::tab:hover {
    background-color: #e8e8e8;
    color: #333333;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #333333;
    border-bottom: 2px solid #0078d4;
}

QTabBar::tab:first {
    border-top-left-radius: 4px;
}

QTabBar::tab:last {
    border-top-right-radius: 4px;
    margin-right: 0;
}

/* йҚ’жҘ„гҖғйҚңеұҫзҲІиӨ°гҲЈоқӢйҚҘ?*/
QListView, QTreeView {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
    outline: none;
}

QListView::item, QTreeView::item {
    padding: 4px;
    min-height: 25px;
    border: none;
}

QListView::item:hover, QTreeView::item:hover {
    background-color: #f5f5f5;
}

QListView::item:selected, QTreeView::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}

QTreeView::branch {
    background-color: #ffffff;
}

QTreeView::branch:has-children:!has-siblings:closed,
QTreeView::branch:closed:has-children:has-siblings {
    image: url(data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iOCIgaGVpZ2h0PSIxMiIgdmlld0JveD0iMCAwIDggMTIiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTEgMUw2IDZMMSAxMSIgc3Ryb2tlPSIjMzMzMzMzIiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCIvPjwvc3ZnPg==);
}

QTreeView::branch:open:has-children:!has-siblings,
QTreeView::branch:open:has-children:has-siblings {
    image: url(data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iOCIgdmlld0JveD0iMCAwIDEyIDgiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTEgMUw2IDZMMTEgMSIgc3Ryb2tlPSIjMzMzMzMzIiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCIvPjwvc3ZnPg==);
}

QTableView, QTableWidget {
    background-color: #ffffff;
    alternate-background-color: #ffffff;
    color: #1f2328;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 0;
    gridline-color: transparent;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
    outline: none;
}

QTableView::item, QTableWidget::item {
    padding: 0 8px;
    border: none;
    background-color: transparent;
    color: #1f2328;
}

QTableView::item:hover, QTableWidget::item:hover {
    background-color: transparent;
    color: #1f2328;
}

QTableView::item:selected, QTableWidget::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}

QTableView::item:selected:hover, QTableWidget::item:selected:hover {
    background-color: #0078d4;
    color: #ffffff;
}

QTableView QHeaderView,
QTableWidget QHeaderView {
    background: transparent;
    border: none;
    outline: none;
    margin: 0;
    padding: 0;
}

QTableView QHeaderView::section,
QTableWidget QHeaderView::section {
    background-color: #ffffff;
    color: #5f6b7a;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    padding: 0 8px;
    font-weight: 600;
    margin: 0;
}

QTableView QHeaderView::section:hover,
QTableWidget QHeaderView::section:hover {
    background-color: #ffffff;
    color: #5f6b7a;
}

QTableView QTableCornerButton::section,
QTableWidget QTableCornerButton::section,
QTableView QAbstractScrollArea::corner,
QTableWidget QAbstractScrollArea::corner,
QTableView::corner,
QTableWidget::corner {
    background: transparent;
    border: none;
}

QTableView QScrollBar:vertical,
QTableWidget QScrollBar:vertical {
    background-color: transparent;
    width: 12px;
    margin: 3px 2px 3px 0;
    border: none;
}

QTableView QScrollBar::handle:vertical,
QTableWidget QScrollBar::handle:vertical {
    background-color: rgba(0, 0, 0, 0.22);
    border-radius: 4px;
    min-height: 28px;
    margin: 0;
}

QTableView QScrollBar::handle:vertical:hover,
QTableWidget QScrollBar::handle:vertical:hover {
    background-color: rgba(0, 0, 0, 0.32);
}

QTableView QScrollBar::add-line:vertical,
QTableView QScrollBar::sub-line:vertical,
QTableWidget QScrollBar::add-line:vertical,
QTableWidget QScrollBar::sub-line:vertical {
    height: 0;
    background: transparent;
    border: none;
}

QTableView QScrollBar::add-page:vertical,
QTableView QScrollBar::sub-page:vertical,
QTableWidget QScrollBar::add-page:vertical,
QTableWidget QScrollBar::sub-page:vertical {
    background: transparent;
}

QTableView QScrollBar:horizontal,
QTableWidget QScrollBar:horizontal {
    background-color: transparent;
    height: 12px;
    margin: 0 3px 2px 3px;
    border: none;
}

QTableView QScrollBar::handle:horizontal,
QTableWidget QScrollBar::handle:horizontal {
    background-color: rgba(0, 0, 0, 0.22);
    border-radius: 4px;
    min-width: 28px;
    margin: 0;
}

QTableView QScrollBar::handle:horizontal:hover,
QTableWidget QScrollBar::handle:horizontal:hover {
    background-color: rgba(0, 0, 0, 0.32);
}

QTableView QScrollBar::add-line:horizontal,
QTableView QScrollBar::sub-line:horizontal,
QTableWidget QScrollBar::add-line:horizontal,
QTableWidget QScrollBar::sub-line:horizontal {
    width: 0;
    background: transparent;
    border: none;
}

QTableView QScrollBar::add-page:horizontal,
QTableView QScrollBar::sub-page:horizontal,
QTableWidget QScrollBar::add-page:horizontal,
QTableWidget QScrollBar::sub-page:horizontal {
    background: transparent;
}

QFrame[tableCard="true"] {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
}

QFrame[tableCard="true"] QTableView,
QFrame[tableCard="true"] QTableWidget {
    border: none;
    border-radius: 0;
}

/* ең°еӣҫеҜјиҲӘеӯҗеј№зӘ— */
QDialog#mapNavPreviewDialog QLabel#minimapPreviewImage {
    background-color: #fafafa;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    padding: 8px;
}

QDialog#mapNavPreviewDialog QLabel#minimapPreviewInfo,
QLabel#routeVisibilitySummaryLabel,
QLabel#routePointActionSummaryLabel,
QLabel#mapSelectorRouteSummary,
QLabel#routeVisibilityCategoryCount,
QLabel#routeVisibilityEmptyLabel,
QLabel#routePointActionCategoryCount,
QLabel#routePointActionDetailLabel,
QLabel#routePointActionEmptyLabel {
    color: #666666;
}

QLabel#routeVisibilityTip,
QLabel#routePointActionTip,
QLabel#mapSelectorTip {
    background-color: #ffffff;
    color: #666666;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 8px 10px;
}

QLabel#routeVisibilityCategoryTitle,
QLabel#routePointActionCategoryTitle {
    font-weight: 600;
}

QScrollArea#routeVisibilityScrollArea,
QWidget#routeVisibilityScrollContent,
QScrollArea#routePointActionScrollArea,
QWidget#routePointActionScrollContent {
    background: transparent;
    border: none;
}

QWidget#mapNavLockOverlay {
    background: transparent;
}

/* зҗӣг„ҘгҒ” */
QHeaderView::section {
    background-color: #f5f5f5;
    color: #333333;
    border: none;
    border-right: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
    padding: 6px;
}

QHeaderView::section:hover {
    background-color: #e8e8e8;
}

/* е©Ҡж°¬е§©йҸү?*/
